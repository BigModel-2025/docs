{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "BigModel",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "api": {
    "openapi": [
      "openapi.json"
    ],
    "playground": {
      "display": "interactive",
      "proxy": false
    },
    "examples": {
      "languages": [
        "bash",
        "python",
        "javascript"
      ],
      "defaults": "required"
    }
  },
  "redirects": [
    {
      "source": "/home",
      "destination": "/api-reference/introduction"
    }
  ],
  "navigation": {
    "versions": [
      {
        "version": "English",
        "tabs": [
          {
            "tab": "Guides",
            "groups": [
              {
                "group": "Get Started",
                "icon": "stars",
                "pages": [
                  "introduction",
                  "quickstart",
                  "development"
                ]
              },
              {
                "group": "Essentials",
                "pages": [
                  "essentials/markdown",
                  "essentials/code",
                  "essentials/images",
                  "essentials/settings",
                  "essentials/navigation",
                  "essentials/reusable-snippets"
                ]
              }
            ]
          },
          {
            "tab": "API Reference",
            "groups": [
              {
                "group": "API Documentation",
                "pages": [
                  "api-reference/introduction"
                ]
              },
              {
                "group": "Chat",
                "pages": [
                  "api-reference/chat-completions/chat-completions"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/dark.svg",
    "dark": "/logo/light.svg",
    "href": "https://bigmodel.cn"
  },
  "footer": {
    "socials": {}
  },
  "integrations": {
    "ga4": {
      "measurementId": "G-RCYWHL7EQ7"
    },
    "koala": {
      "publicApiKey": "pk_76a6caa274e800f3ceff0b2bc6b9b9d82ab8"
    }
  }
}